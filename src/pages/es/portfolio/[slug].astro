---
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { render } from 'astro:content';
import FaslLayout from '~/layouts/FaslLayout.astro';
import { getProducts } from '~/utils/products';
import { t } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';
import type { Locale } from '~/utils/i18n';

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((product) => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const locale: Locale = 'es';
const d = product.data;
const dateStr = d.date.toLocaleDateString('es-CL', { year: 'numeric', month: 'long' });
const categoryLabel = t(`category.${d.category}`, locale);

const { Content } = await render(product);

const allDiagrams = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/projects/diagrams/*.svg', { eager: true });
const allScreenshots = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/projects/screenshots/*.png', { eager: true });
const allRollings = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/projects/rollings/*.svg', { eager: true });

function findAssets(glob: Record<string, { default: ImageMetadata }>, patterns: string[]) {
  return Object.entries(glob)
    .filter(([path]) => patterns.some(p => path.toLowerCase().includes(p.toLowerCase())))
    .map(([path, mod]) => ({ path, image: mod.default }));
}

const slugPatterns = d.assetPatterns || [d.slug];
const diagrams = findAssets(allDiagrams, slugPatterns);
const screenshots = findAssets(allScreenshots, slugPatterns);
const rollings = findAssets(allRollings, slugPatterns);
---

<FaslLayout metadata={{ title: d.titleEs, description: d.excerptEs }} locale={locale}>
  <article class="py-12 md:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6">
      <a href={getPermalink('/es/portfolio')} class="mb-8 inline-flex items-center gap-1 text-sm text-muted hover:text-primary transition-colors">
        ← {t('portfolio.back', locale)}
      </a>

      <header class="mb-12">
        <div class="mb-4 flex flex-wrap items-center gap-3">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
            <Icon name={d.icon} class="h-5 w-5" />
          </div>
          <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">{categoryLabel}</span>
          <span class="text-sm text-muted">{dateStr}</span>
          {d.proprietary && (
            <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-800 dark:bg-amber-900/30 dark:text-amber-400">
              <Icon name="tabler:lock" class="h-3.5 w-3.5" /> Propietario
            </span>
          )}
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl md:text-5xl leading-tight">{d.titleEs}</h1>
        <p class="mt-6 text-xl leading-relaxed text-muted max-w-3xl">{d.excerptEs}</p>

        {(d.github || d.demo || d.video || d.publication || d.website) && (
          <div class="mt-6 flex flex-wrap gap-3">
            {d.github && (
              <a href={d.github} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-medium text-white hover:bg-gray-700 dark:bg-gray-700 dark:hover:bg-gray-600 transition-colors">
                <Icon name="tabler:brand-github" class="h-4 w-4" /> Código Fuente
              </a>
            )}
            {d.demo && (
              <a href={d.demo} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-white hover:bg-secondary transition-colors">
                <Icon name="tabler:external-link" class="h-4 w-4" /> Demo
              </a>
            )}
            {d.website && (
              <a href={d.website} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-medium text-white hover:bg-secondary transition-colors">
                <Icon name="tabler:world" class="h-4 w-4" /> Sitio Web
              </a>
            )}
            {d.video && (
              <a href={d.video} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800 transition-colors">
                <Icon name="tabler:brand-youtube" class="h-4 w-4" /> Video
              </a>
            )}
            {d.publication && (
              <a href={d.publication} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-100 dark:border-gray-600 dark:text-gray-300 dark:hover:bg-gray-800 transition-colors">
                <Icon name="tabler:file-text" class="h-4 w-4" /> Publicación
              </a>
            )}
          </div>
        )}
      </header>

      <div class="mb-14 grid grid-cols-2 gap-4 md:grid-cols-4">
        {d.metrics.map((m) => (
          <div class="rounded-xl border border-gray-200 bg-white p-5 text-center dark:border-gray-700/50 dark:bg-gray-800/60 shadow-sm">
            <div class="text-xs font-semibold uppercase tracking-wider text-primary mb-2">{m.labelEs}</div>
            <div class="text-sm font-bold text-gray-900 dark:text-white leading-snug">{m.valueEs}</div>
          </div>
        ))}
      </div>

      {diagrams.length > 0 && (
        <section class="mb-14">
          <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
            <Icon name="tabler:hierarchy-3" class="h-6 w-6 text-primary" /> {t('section.architecture', locale)}
          </h2>
          <div class="space-y-6">
            {diagrams.map(({ image }) => (
              <div class="rounded-xl border border-gray-200 bg-white p-4 dark:border-gray-700/50 dark:bg-gray-800/30 overflow-hidden">
                <Image src={image} alt={`${d.titleEs} — Arquitectura`} class="w-full h-auto" loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="mb-12">
        <h2 class="mb-4 text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <Icon name="tabler:alert-triangle" class="h-6 w-6 text-amber-500" /> {t('section.challenge', locale)}
        </h2>
        <div class="rounded-xl bg-amber-50/50 border border-amber-200/50 p-6 dark:bg-amber-900/10 dark:border-amber-800/30">
          <p class="text-base leading-relaxed text-gray-700 dark:text-gray-300">{d.challengeEs}</p>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="mb-4 text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <Icon name="tabler:bulb" class="h-6 w-6 text-primary" /> {t('section.approach', locale)}
        </h2>
        <div class="rounded-xl bg-primary/5 border border-primary/20 p-6">
          <p class="text-base leading-relaxed text-gray-700 dark:text-gray-300">{d.approachEs}</p>
        </div>
      </section>

      {rollings.length > 0 && (
        <section class="mb-14">
          <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
            <Icon name="tabler:chart-dots" class="h-6 w-6 text-primary" /> Detalles Técnicos
          </h2>
          <div class="grid gap-6 md:grid-cols-2">
            {rollings.map(({ image, path }) => {
              const fileName = path.split('/').pop()?.replace('.svg', '').replace(/_/g, ' ') || '';
              return (
                <div class="rounded-xl border border-gray-200 bg-white p-4 dark:border-gray-700/50 dark:bg-gray-800/30">
                  <Image src={image} alt={fileName} class="w-full h-auto mb-2" loading="lazy" />
                  <p class="text-xs text-center text-muted capitalize">{fileName}</p>
                </div>
              );
            })}
          </div>
        </section>
      )}

      {screenshots.length > 0 && (
        <section class="mb-14">
          <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
            <Icon name="tabler:device-desktop" class="h-6 w-6 text-primary" /> Aplicación
          </h2>
          <div class="space-y-6">
            {screenshots.map(({ image }) => (
              <div class="rounded-xl border border-gray-200 bg-white p-2 dark:border-gray-700/50 dark:bg-gray-800/30 shadow-lg overflow-hidden">
                <Image src={image} alt={`${d.titleEs} — Captura`} class="w-full h-auto rounded-lg" loading="lazy" />
              </div>
            ))}
          </div>
        </section>
      )}

      <section class="mb-14">
        <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <Icon name="tabler:chart-bar" class="h-6 w-6 text-primary" /> {t('section.kpis', locale)}
        </h2>
        <div class="overflow-x-auto rounded-xl border border-gray-200 dark:border-gray-700/50">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-gray-50 dark:bg-gray-800/80">
                <th class="px-5 py-4 text-left font-semibold text-gray-900 dark:text-white">KPI</th>
                <th class="px-5 py-4 text-left font-semibold text-gray-900 dark:text-white">Línea Base</th>
                <th class="px-5 py-4 text-left font-semibold text-gray-900 dark:text-white">Resultado</th>
                <th class="px-5 py-4 text-left font-semibold text-gray-900 dark:text-white">Impacto</th>
              </tr>
            </thead>
            <tbody>
              {d.kpis.map((kpi, i) => (
                <tr class:list={['border-t border-gray-100 dark:border-gray-800', { 'bg-gray-50/50 dark:bg-gray-800/20': i % 2 === 0 }]}>
                  <td class="px-5 py-4 font-medium text-gray-900 dark:text-white">{kpi.labelEs}</td>
                  <td class="px-5 py-4 text-muted">{kpi.baselineEs}</td>
                  <td class="px-5 py-4 font-semibold text-primary">{kpi.resultEs}</td>
                  <td class="px-5 py-4 text-muted">{kpi.impactEs}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Body content is English-only; ES version relies on translated
           frontmatter fields (challengeEs, approachEs, KPIs, metrics)
           which are shown in the sections above. -->

      <section class="mb-14">
        <h2 class="mb-6 text-2xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <Icon name="tabler:stack-2" class="h-6 w-6 text-primary" /> {t('section.stack', locale)}
        </h2>
        <div class="flex flex-wrap gap-2">
          {d.stack.map((tech) => (
            <span class="inline-flex items-center rounded-lg border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm dark:border-gray-600 dark:bg-gray-800 dark:text-gray-300">{tech}</span>
          ))}
        </div>
      </section>

      <section class="mb-10">
        <div class="flex flex-wrap gap-2">
          {d.tags.map((tag) => (
            <span class="inline-flex items-center rounded-full bg-primary/10 px-3 py-1 text-sm font-medium text-primary">#{tag}</span>
          ))}
        </div>
      </section>

      {d.proprietary && (
        <div class="mb-10 rounded-xl bg-amber-50 border border-amber-200 p-4 dark:bg-amber-900/10 dark:border-amber-800/30">
          <p class="text-sm text-amber-800 dark:text-amber-400 flex items-center gap-2">
            <Icon name="tabler:lock" class="h-4 w-4" /> {t('product.proprietary', locale)}
          </p>
        </div>
      )}

      <div class="pt-8 border-t border-gray-200 dark:border-gray-700">
        <a href={getPermalink('/es/portfolio')} class="inline-flex items-center gap-2 rounded-full border border-primary px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white">
          ← {t('portfolio.back', locale)}
        </a>
      </div>
    </div>
  </article>
</FaslLayout>
