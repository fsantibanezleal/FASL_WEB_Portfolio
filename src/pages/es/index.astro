---
import FaslLayout from '~/layouts/FaslLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';

import { getFeaturedProducts } from '~/utils/products';
import { t } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

import bannerImage from '~/assets/images/fasl-banner-dark.png';

const locale = 'es';
const featured = await getFeaturedProducts();

const metadata = {
  title: 'FASL.work — Ingeniería y Tecnología Aplicada',
  ignoreTitleTemplate: true,
};
---

<FaslLayout metadata={metadata} locale={locale}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: t('hero.cta.portfolio', locale),
        href: getPermalink('/es/portfolio'),
        icon: 'tabler:briefcase',
      },
      {
        text: t('hero.cta.contact', locale),
        href: getPermalink('/es/contact'),
        icon: 'tabler:mail',
      },
    ]}
    image={{ src: bannerImage, alt: 'FASL.work Banner' }}
  >
    <Fragment slot="title">
      {t('hero.title.line1', locale)}<br />
      <span class="text-primary">{t('hero.title.line2', locale)}</span>
    </Fragment>

    <Fragment slot="subtitle">
      {t('hero.subtitle', locale)}
    </Fragment>
  </Hero>

  <Stats
    stats={[
      { title: t('stats.projects', locale), amount: '39+' },
      { title: t('stats.years', locale), amount: '15+' },
      { title: t('stats.industries', locale), amount: '6' },
      { title: t('stats.technologies', locale), amount: '50+' },
    ]}
  />

  <section class="py-12 md:py-20" id="portfolio">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mb-12 text-center">
        <p class="text-base font-semibold uppercase tracking-wide text-primary">{t('portfolio.tagline', locale)}</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          {t('portfolio.title', locale)}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-muted">
          {t('portfolio.subtitle', locale)}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featured.map((product) => <ProductCard {...product.data} locale={locale} />)}
      </div>

      <div class="mt-10 text-center">
        <a
          href={getPermalink('/es/portfolio')}
          class="inline-flex items-center gap-2 rounded-full border border-primary px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
        >
          Ver Todos los Proyectos →
        </a>
      </div>
    </div>
  </section>

  <Features
    id="services"
    tagline={t('services.title', locale)}
    title={t('services.subtitle', locale)}
    items={[
      {
        title: 'Machine Learning e IA',
        description:
          'Plataformas ML end-to-end para optimización industrial, modelado predictivo y visión por computador. Desde ingeniería de características hasta despliegue en producción.',
        icon: 'tabler:brain',
      },
      {
        title: 'Visualización 3D y Nubes de Puntos',
        description:
          'Aplicaciones web 3D interactivas, análisis de nubes de puntos y procesamiento de datos espaciales para minería, manufactura e investigación.',
        icon: 'tabler:cube-3d-sphere',
      },
      {
        title: 'Desarrollo Full-Stack',
        description:
          'Plataformas web de producción con FastAPI, Next.js, React y PostgreSQL. Aplicaciones de escritorio con PyInstaller y Streamlit.',
        icon: 'tabler:code',
      },
      {
        title: 'Ingeniería de Datos y MLOps',
        description:
          'Pipelines Kedro, Databricks, Delta Lake, orquestación Docker Swarm y automatización CI/CD para productos de datos escalables.',
        icon: 'tabler:database',
      },
      {
        title: 'Procesamiento Espectral y de Señales',
        description:
          'Análisis de imágenes hiperespectrales, desmezclado espectral, calibración de sensores y procesamiento de señales para caracterización mineral.',
        icon: 'tabler:wave-sine',
      },
      {
        title: 'Consultoría y Prototipado',
        description:
          'Del concepto a la producción. Prototipado rápido de soluciones de ingeniería con documentación clara y transferencia tecnológica.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <Content
    id="about"
    isReversed
    tagline="Acerca de"
    title="Acerca de FASL.work"
    items={[
      {
        title: 'Fundada por un PhD en Ingeniería Eléctrica',
        description:
          'Más de 15 años de experiencia en investigación aplicada, optimización industrial y desarrollo de software en minería, microscopía y accesibilidad.',
      },
      {
        title: 'De la Investigación a la Producción',
        description:
          'Conectamos la brecha entre investigación académica y despliegue industrial, entregando soluciones que funcionan en el mundo real.',
      },
      {
        title: 'Open Source e Industria',
        description:
          'Un portafolio que abarca herramientas de investigación de código abierto, plataformas industriales propietarias y proyectos de accesibilidad.',
      },
    ]}
    image={{
      src: bannerImage,
      alt: 'FASL.work',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Investigación · Hardware · Soluciones Digitales
      </h3>
      {t('about.description', locale)}
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Ver Portafolio',
        href: getPermalink('/es/portfolio'),
        icon: 'tabler:briefcase',
      },
      {
        text: 'GitHub',
        href: 'https://github.com/fsantibanezleal',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
  >
    <Fragment slot="title">
      Construyamos<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> Algo Grande</span>
    </Fragment>

    <Fragment slot="subtitle">
      Explora nuestro portafolio de soluciones de ingeniería o contáctanos para discutir tu próximo proyecto.
    </Fragment>
  </CallToAction>
</FaslLayout>
