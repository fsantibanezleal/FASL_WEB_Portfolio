---
import FaslLayout from '~/layouts/FaslLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductCard from '~/components/widgets/ProductCard.astro';

import { getFeaturedProducts } from '~/utils/products';
import { t } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

import bannerImage from '~/assets/images/fasl-banner-dark.png';

const locale = 'en';
const featured = await getFeaturedProducts();

const metadata = {
  title: 'FASL.work — Engineering & Applied Technology',
  ignoreTitleTemplate: true,
};
---

<FaslLayout metadata={metadata} locale={locale}>
  <!-- Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: t('hero.cta.portfolio', locale),
        href: getPermalink('/portfolio'),
        icon: 'tabler:briefcase',
      },
      {
        text: t('hero.cta.contact', locale),
        href: getPermalink('/contact'),
        icon: 'tabler:mail',
      },
    ]}
    image={{ src: bannerImage, alt: 'FASL.work Banner' }}
  >
    <Fragment slot="title">
      {t('hero.title.line1', locale)}<br />
      <span class="text-primary">{t('hero.title.line2', locale)}</span>
    </Fragment>

    <Fragment slot="subtitle">
      {t('hero.subtitle', locale)}
    </Fragment>
  </Hero>

  <!-- Stats -->
  <Stats
    stats={[
      { title: t('stats.projects', locale), amount: '39+' },
      { title: t('stats.years', locale), amount: '15+' },
      { title: t('stats.industries', locale), amount: '6' },
      { title: t('stats.technologies', locale), amount: '50+' },
    ]}
  />

  <!-- Featured Products -->
  <section class="py-12 md:py-20" id="portfolio">
    <div class="mx-auto max-w-7xl px-4 sm:px-6">
      <div class="mb-12 text-center">
        <p class="text-base font-semibold uppercase tracking-wide text-primary">{t('portfolio.tagline', locale)}</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
          {t('portfolio.title', locale)}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-muted">
          {t('portfolio.subtitle', locale)}
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {featured.map((product) => (
          <ProductCard {...product.data} locale={locale} />
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href={getPermalink('/portfolio')}
          class="inline-flex items-center gap-2 rounded-full border border-primary px-6 py-3 text-sm font-semibold text-primary transition-colors hover:bg-primary hover:text-white"
        >
          View All Projects →
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Features
    id="services"
    tagline={t('services.title', locale)}
    title={t('services.subtitle', locale)}
    items={[
      {
        title: 'Machine Learning & AI',
        description: 'End-to-end ML platforms for industrial optimization, predictive modeling, and computer vision. From feature engineering to production deployment.',
        icon: 'tabler:brain',
      },
      {
        title: '3D Visualization & Point Cloud',
        description: 'Interactive 3D web applications, point cloud analysis, and spatial data processing for mining, manufacturing, and research applications.',
        icon: 'tabler:cube-3d-sphere',
      },
      {
        title: 'Full-Stack Development',
        description: 'Production-grade web platforms with FastAPI, Next.js, React, and PostgreSQL. Desktop applications with PyInstaller and Streamlit.',
        icon: 'tabler:code',
      },
      {
        title: 'Data Engineering & MLOps',
        description: 'Kedro pipelines, Databricks, Delta Lake, Docker Swarm orchestration, and CI/CD automation for scalable data products.',
        icon: 'tabler:database',
      },
      {
        title: 'Spectral & Signal Processing',
        description: 'Hyperspectral image analysis, spectral unmixing, sensor calibration, and signal processing for mineral characterization and quality control.',
        icon: 'tabler:wave-sine',
      },
      {
        title: 'Consulting & Prototyping',
        description: 'From proof-of-concept to production. Rapid prototyping of engineering solutions with clear documentation and technology transfer.',
        icon: 'tabler:bulb',
      },
    ]}
  />

  <!-- About -->
  <Content
    id="about"
    isReversed
    tagline="About"
    title="About FASL.work"
    items={[
      {
        title: 'Founded by a PhD in Electrical Engineering',
        description: 'Over 15 years of experience in applied research, industrial optimization, and software engineering across mining, microscopy, and accessibility.',
      },
      {
        title: 'From Research to Production',
        description: 'We bridge the gap between academic research and industrial deployment, delivering solutions that work in the real world.',
      },
      {
        title: 'Open Source & Industry',
        description: 'A portfolio spanning open-source research tools, proprietary industrial platforms, and accessibility-focused projects.',
      },
    ]}
    image={{
      src: bannerImage,
      alt: 'FASL.work',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Research · Hardware · Digital Solutions</h3>
      {t('about.description', locale)}
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- CTA -->
  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'View Portfolio',
        href: getPermalink('/portfolio'),
        icon: 'tabler:briefcase',
      },
      {
        text: 'GitHub',
        href: 'https://github.com/fsantibanezleal',
        target: '_blank',
        icon: 'tabler:brand-github',
      },
    ]}
  >
    <Fragment slot="title">
      Let's Build<br class="block sm:hidden" /><span class="sm:whitespace-nowrap"> Something Great</span>
    </Fragment>

    <Fragment slot="subtitle">
      Explore our portfolio of engineering solutions or get in touch to discuss your next project.
    </Fragment>
  </CallToAction>
</FaslLayout>
