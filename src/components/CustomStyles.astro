---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(41 182 246);
    --aw-color-secondary: rgb(2 119 189);
    --aw-color-accent: rgb(79 195 247);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(250 251 252);

    --aw-color-bg-page-dark: rgb(13 17 23);

    ::selection {
      background-color: rgb(41 182 246 / 30%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(41 182 246);
    --aw-color-secondary: rgb(79 195 247);
    --aw-color-accent: rgb(2 119 189);

    --aw-color-text-heading: rgb(237 242 247);
    --aw-color-text-default: rgb(209 219 233);
    --aw-color-text-muted: rgb(209 219 233 / 66%);
    --aw-color-bg-page: rgb(13 17 23);

    ::selection {
      background-color: rgb(41 182 246 / 40%);
      color: snow;
    }
  }
</style>
