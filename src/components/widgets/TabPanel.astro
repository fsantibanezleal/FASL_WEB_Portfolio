---
interface Props {
  tabs: string[];
  id?: string;
}

const { tabs, id = 'tab-panel' } = Astro.props;
---

<div id={id} class="tab-panel">
  <nav class="mb-8 border-b border-gray-200 dark:border-gray-700">
    <ul class="flex flex-wrap -mb-px gap-1" role="tablist">
      {
        tabs.map((tab, i) => (
          <li role="presentation">
            <button
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              data-tab-target={tab}
              class:list={[
                'tab-button inline-flex items-center gap-2 px-5 py-3 text-sm font-medium border-b-2 transition-all duration-200 cursor-pointer',
                i === 0
                  ? 'border-primary text-primary'
                  : 'border-transparent text-muted hover:text-gray-700 hover:border-gray-300 dark:hover:text-gray-300',
              ]}
            >
              {tab}
            </button>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="tab-content">
    <slot />
  </div>
</div>

<style>
  /* Hide all tab panes except the first one by default (CSS-level, no JS needed for initial state) */
  .tab-content > [data-tab] {
    display: none;
  }
  .tab-content > [data-tab]:first-child {
    display: block;
  }
</style>

<script>
  function initTabs() {
    document.querySelectorAll('.tab-panel').forEach((panel) => {
      const buttons = panel.querySelectorAll('.tab-button');
      const contents = panel.querySelectorAll('.tab-content > [data-tab]');

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-tab-target');

          buttons.forEach((b) => {
            b.classList.remove('border-primary', 'text-primary');
            b.classList.add('border-transparent', 'text-muted');
            b.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('border-primary', 'text-primary');
          btn.classList.remove('border-transparent', 'text-muted');
          btn.setAttribute('aria-selected', 'true');

          contents.forEach((c) => {
            (c as HTMLElement).style.display = c.getAttribute('data-tab') === target ? 'block' : 'none';
          });
        });
      });
    });
  }

  // Works with both regular page load and Astro View Transitions
  initTabs();
  document.addEventListener('astro:page-load', initTabs);
</script>
